# AchSwap Docs + AI Assistant - Root .env
# Copy to .env and fill values. Do NOT commit real secrets.
#
# Used by:
# - npm run index-docs (RAG indexing)
# - npm run build (for WORKER_URL injection into frontend)
# - npm run dev (local AI)

# === For local Qdrant + indexing ===
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=achswap-docs
# QDRANT_API_KEY=your-key-if-needed

# === For AI Worker (used at build time for frontend) ===
# For local dev: leave unset (npm run dev handles localhost:8787)
# For production: set to your deployed Cloudflare Worker URL
# WORKER_URL=https://achswap-ai-worker.yourname.workers.dev

# Optional embedding model override
# EMBED_MODEL=Xenova/bge-small-en-v1.5

# Note: For the Cloudflare Worker itself (when using dashboard), 
# set QDRANT_* , CEREBRAS_* and CHAT_API as Variables/Secrets in the dashboard UI.
