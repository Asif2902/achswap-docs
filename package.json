{
  "name": "achswap-docs",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=20 <25",
    "npm": ">=10"
  },
  "scripts": {
    "docusaurus": "docusaurus",
    "start": "docusaurus start",
    "dev": "concurrently -n \"DOCS,WORKER\" -c \"blue,green\" \"docusaurus start\" \"wrangler dev --config worker/wrangler.toml\"",
    "build": "docusaurus build",
    "preview": "npm run build && wrangler dev",
    "deploy": "npm run build && wrangler deploy",
    "clear": "docusaurus clear",
    "write-heading-ids": "docusaurus write-heading-ids",
    "index-docs": "tsx scripts/index-docs.ts",
    "index-docs:force": "tsx scripts/index-docs.ts --force",
    "index-docs:dry": "tsx scripts/index-docs.ts --dry-run",
    "worker:dev": "wrangler dev --config worker/wrangler.toml",
    "setup": "npm install --silent --no-audit --no-fund && (cd worker && npm install --silent --no-audit --no-fund || true) && echo 'Setup complete. Create .env from .env.example with your values, then run npm run dev or npm run index-docs.'",
    "build:prod": "npm run build"
  },
  "dependencies": {
    "@docusaurus/core": "3.10.1",
    "@docusaurus/preset-classic": "3.10.1",
    "@mdx-js/react": "^3.1.0",
    "clsx": "^2.1.1",
    "prism-react-renderer": "^2.4.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@qdrant/qdrant-js": "^1.18.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@xenova/transformers": "^2.17.2",
    "concurrently": "^10.0.3",
    "dotenv": "^17.4.2",
    "glob": "^13.0.6",
    "gray-matter": "^4.0.3",
    "lucide-react": "^1.23.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tsx": "^4.23.0",
    "typescript": "^5.6.3",
    "wrangler": "^4.110.0"
  }
}
