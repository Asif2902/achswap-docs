# For local documentation indexing (scripts/index-docs.ts)
# Copy to .env and fill values. Do NOT commit real secrets.

QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=achswap-docs
# QDRANT_API_KEY=   # only if using Qdrant Cloud or secured instance

# Optional: override model (Xenova/bge-small-en-v1.5 is default and recommended)
# EMBED_MODEL=Xenova/bge-small-en-v1.5
